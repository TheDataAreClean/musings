{#
  Table of Contents component.
  Pass headings extracted from content.
  Usage: {% include "components/toc.njk" %}
#}
{% if toc and toc.length %}
<nav class="doc-toc" aria-label="Table of contents">
  <span class="doc-toc__title">Contents</span>
  <ol class="doc-toc__list">
    {% for item in toc %}
    <li class="doc-toc__item">
      <a class="doc-toc__link" href="#{{ item.id }}">{{ item.text }}</a>
      {% if item.children and item.children.length %}
      <ol class="doc-toc__list">
        {% for child in item.children %}
        <li class="doc-toc__item">
          <a class="doc-toc__link" href="#{{ child.id }}">{{ child.text }}</a>
        </li>
        {% endfor %}
      </ol>
      {% endif %}
    </li>
    {% endfor %}
  </ol>
</nav>
{% endif %}
