<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title != "Home" %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="author" content="{{ site.author }}">
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/ideas/feed.xml">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  {# ── STATIC DECORATION ONLY — nothing below is interactive ───────────── #}

  {# Title bar: app name left · document name centre · save state right #}
  <div class="app-titlebar" aria-hidden="true">
    <span class="app-titlebar__app">{{ site.title }}</span>
    <span class="app-titlebar__doc">{{ title or site.title }}</span>
    <span class="app-titlebar__saved">All changes saved</span>
  </div>

  {# Menu bar: all items are dead text — black, readable, unresponsive #}
  <div class="app-menubar" aria-hidden="true">
    <span class="app-menubar__item">File</span>
    <span class="app-menubar__item">Edit</span>
    <span class="app-menubar__item">View</span>
    <span class="app-menubar__item">Insert</span>
    <span class="app-menubar__item">Format</span>
    <span class="app-menubar__item">Tools</span>
    <span class="app-menubar__item">Help</span>
  </div>

  {# Toolbar: realistic content, denser, correct glyphs #}
  <div class="app-toolbar" aria-hidden="true">
    <span class="app-toolbar__select">Normal text ▾</span>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-toolbar__select">Arial ▾</span>
    <span class="app-toolbar__select app-toolbar__select--size">12 ▾</span>
    <span class="app-toolbar__pipe">|</span>
    <b class="app-toolbar__fmt">B</b>
    <i class="app-toolbar__fmt">I</i>
    <u class="app-toolbar__fmt">U</u>
    <s class="app-toolbar__fmt">S</s>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-toolbar__fmt">A ▾</span>
    <span class="app-toolbar__fmt">¶</span>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-toolbar__fmt">&#8644;</span>
    <span class="app-toolbar__fmt">&#8644;</span>
    <span class="app-toolbar__fmt">&#8644;</span>
    <span class="app-toolbar__fmt">&#8644;</span>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-toolbar__fmt">&#8676;</span>
    <span class="app-toolbar__fmt">&#8677;</span>
    <span class="app-toolbar__spacer"></span>
    <span class="app-toolbar__select">100% ▾</span>
  </div>

  {# Ruler: tick marks + inch numbers in HTML #}
  <div class="app-ruler" aria-hidden="true">
    <div class="app-ruler__zone">
      <span class="app-ruler__num" style="--i: 1">1</span>
      <span class="app-ruler__num" style="--i: 2">2</span>
      <span class="app-ruler__num" style="--i: 3">3</span>
      <span class="app-ruler__num" style="--i: 4">4</span>
      <span class="app-ruler__num" style="--i: 5">5</span>
      <span class="app-ruler__num" style="--i: 6">6</span>
    </div>
  </div>

  {# ── REAL CONTENT LIVES HERE ─────────────────────────────────────────── #}

  <div class="app-canvas">

    {# Navigation — plain links on the grey desk, above the page card #}
    <nav class="app-nav" aria-label="Site navigation">
      <a href="/">Home</a>
      <span aria-hidden="true">·</span>
      <a href="/works/">Works</a>
      <span aria-hidden="true">·</span>
      <a href="/ideas/">Ideas</a>
      <span aria-hidden="true">·</span>
      <a href="/about/">About</a>
    </nav>

    <main id="main" role="main">
      {{ content | safe }}
    </main>

  </div>

  {# Status bar — static decoration #}
  <div class="app-statusbar" aria-hidden="true">
    <span class="app-statusbar__item">Page 1</span>
    <span class="app-statusbar__item">English (UK)</span>
    <span class="app-statusbar__spacer"></span>
    <span class="app-statusbar__item">100%</span>
  </div>

</body>
</html>
