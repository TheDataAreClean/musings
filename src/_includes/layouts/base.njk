<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title != "Home" %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="author" content="{{ site.author }}">
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/ideas/feed.xml">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  {# ── STATIC DECORATION ONLY — nothing below is interactive ───────────── #}

  {# Title bar: stoplight left · document name centre · save state right #}
  <div class="app-titlebar" aria-hidden="true">
    <div class="app-titlebar__left">
      <div class="stoplight">
        <button class="stoplight__red" title="Close tab"></button>
        <span class="stoplight__yellow"></span>
        <span class="stoplight__green"></span>
      </div>
    </div>
    <span class="app-titlebar__doc">{{ title or site.title }}</span>
    <span class="app-titlebar__saved">{{ site.chrome.saveState }}</span>
  </div>

  {# Menu bar: all items are dead text — black, readable, unresponsive #}
  <div class="app-menubar" aria-hidden="true">
    {% for item in site.chrome.menu %}
    <span class="app-menubar__item">{{ item }}</span>
    {% endfor %}
  </div>

  {# Toolbar: realistic content, denser, correct glyphs #}
  <div class="app-toolbar" aria-hidden="true">
    <span class="app-toolbar__select">{{ site.chrome.styleLabel }} ▾</span>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-dropdown app-toolbar__font" aria-hidden="true">
      <span class="app-dropdown__label">Arial</span>&#8200;&#9662;
      <div class="app-dropdown__menu">
        <div class="app-dropdown__option app-dropdown__option--selected" data-value="arial">Arial</div>
        <div class="app-dropdown__option" data-value="georgia">Georgia</div>
      </div>
    </span>
    <span class="app-toolbar__select app-toolbar__select--size">{{ site.chrome.fontSize }} ▾</span>
    <span class="app-toolbar__pipe">|</span>
    <b class="app-toolbar__fmt">B</b>
    <i class="app-toolbar__fmt">I</i>
    <u class="app-toolbar__fmt">U</u>
    <s class="app-toolbar__fmt">S</s>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-toolbar__fmt">A ▾</span>
    <span class="app-toolbar__fmt">¶</span>
    <span class="app-toolbar__pipe">|</span>
    <span class="app-toolbar__break"></span>
    <span class="app-toolbar__fmt app-toolbar__mobile-hide">&#8644;</span>
    <span class="app-toolbar__fmt app-toolbar__mobile-hide">&#8644;</span>
    <span class="app-toolbar__fmt app-toolbar__mobile-hide">&#8644;</span>
    <span class="app-toolbar__fmt app-toolbar__mobile-hide">&#8644;</span>
    <span class="app-toolbar__pipe app-toolbar__mobile-hide">|</span>
    <span class="app-toolbar__fmt app-toolbar__mobile-hide">&#8676;</span>
    <span class="app-toolbar__fmt app-toolbar__mobile-hide">&#8677;</span>
    <span class="app-toolbar__spacer app-toolbar__mobile-hide"></span>
    <span class="app-dropdown app-dropdown--right app-toolbar__zoom" aria-hidden="true">
      <span class="app-dropdown__label">100%</span>&#8200;&#9662;
      <div class="app-dropdown__menu">
        <div class="app-dropdown__option" data-value="50">50%</div>
        <div class="app-dropdown__option" data-value="75">75%</div>
        <div class="app-dropdown__option" data-value="90">90%</div>
        <div class="app-dropdown__option app-dropdown__option--selected" data-value="100">100%</div>
        <div class="app-dropdown__option" data-value="110">110%</div>
        <div class="app-dropdown__option" data-value="125">125%</div>
        <div class="app-dropdown__option" data-value="150">150%</div>
        <div class="app-dropdown__option" data-value="175">175%</div>
        <div class="app-dropdown__option" data-value="200">200%</div>
      </div>
    </span>
  </div>

  {# Ruler: tick marks + inch numbers in HTML #}
  <div class="app-ruler" aria-hidden="true">
    <div class="app-ruler__zone">
      <span class="app-ruler__num" style="--i: 1">1</span>
      <span class="app-ruler__num" style="--i: 2">2</span>
      <span class="app-ruler__num" style="--i: 3">3</span>
      <span class="app-ruler__num" style="--i: 4">4</span>
      <span class="app-ruler__num" style="--i: 5">5</span>
      <span class="app-ruler__num" style="--i: 6">6</span>
    </div>
  </div>

  {# ── REAL CONTENT LIVES HERE ─────────────────────────────────────────── #}

  <div class="app-canvas">
    <main id="main" role="main">
      {{ content | safe }}
    </main>
  </div>

  {# Status bar — static decoration #}
  <div class="app-statusbar" aria-hidden="true">
    <span class="app-statusbar__item">Page 1</span>
    <span class="app-statusbar__item">{{ site.chrome.language }}</span>
    <span class="app-statusbar__spacer"></span>
    <span class="app-statusbar__item app-statusbar__zoom">{{ site.chrome.zoom }}</span>
  </div>

  <script>
  (function () {

    // ── Shared: custom dropdown ───────────────────────────────────────────────
    function initDropdown(el, onChange) {
      var label   = el.querySelector('.app-dropdown__label');
      var options = el.querySelectorAll('.app-dropdown__option');

      el.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = el.classList.contains('app-dropdown--open');
        // Close all open dropdowns first
        document.querySelectorAll('.app-dropdown--open').forEach(function (d) {
          d.classList.remove('app-dropdown--open');
        });
        if (!isOpen) el.classList.add('app-dropdown--open');
      });

      options.forEach(function (opt) {
        opt.addEventListener('click', function (e) {
          e.stopPropagation();
          options.forEach(function (o) { o.classList.remove('app-dropdown__option--selected'); });
          opt.classList.add('app-dropdown__option--selected');
          label.textContent = opt.textContent;
          el.classList.remove('app-dropdown--open');
          if (onChange) onChange(opt.dataset.value);
        });
      });

      return {
        setValue: function (val) {
          options.forEach(function (o) {
            var match = o.dataset.value === String(val);
            o.classList.toggle('app-dropdown__option--selected', match);
            if (match) label.textContent = o.textContent;
          });
        }
      };
    }

    document.addEventListener('click', function () {
      document.querySelectorAll('.app-dropdown--open').forEach(function (d) {
        d.classList.remove('app-dropdown--open');
      });
    });

    // ── 1. FONT — session-persistent ─────────────────────────────────────────
    var fontMap = {
      arial:   'Arial, Helvetica, sans-serif',
      georgia: 'Georgia, "Times New Roman", serif'
    };

    function applyFont(key) {
      document.documentElement.style.setProperty('--font-doc', fontMap[key] || fontMap.arial);
      sessionStorage.setItem('musings-font', key);
    }

    var fontDropdown = initDropdown(document.querySelector('.app-toolbar__font'), applyFont);

    var savedFont = sessionStorage.getItem('musings-font');
    if (savedFont && fontMap[savedFont]) {
      applyFont(savedFont);
      fontDropdown.setValue(savedFont);
    }

    // ── 2. ZOOM — session-persistent, Cmd/Ctrl +/-/0 ─────────────────────────
    var zoomDropdown = initDropdown(document.querySelector('.app-toolbar__zoom'), function (value) {
      applyZoom(levels.indexOf(Number(value)));
    });

    var zoomStatus = document.querySelector('.app-statusbar__zoom');
    var canvas     = document.querySelector('.app-canvas');
    var levels     = [50, 75, 90, 100, 110, 125, 150, 175, 200];
    var zi         = levels.indexOf(100);

    function applyZoom(i) {
      zi = Math.max(0, Math.min(levels.length - 1, i));
      var pct = levels[zi];
      canvas.style.zoom      = pct / 100;
      zoomStatus.textContent = pct + '%';
      zoomDropdown.setValue(pct);
      sessionStorage.setItem('musings-zoom', pct);
    }

    var savedZoom = sessionStorage.getItem('musings-zoom');
    if (savedZoom) applyZoom(levels.indexOf(Number(savedZoom)));

    document.addEventListener('keydown', function (e) {
      if (!e.metaKey && !e.ctrlKey) return;
      if (e.key === '=' || e.key === '+') { e.preventDefault(); applyZoom(zi + 1); }
      else if (e.key === '-')             { e.preventDefault(); applyZoom(zi - 1); }
      else if (e.key === '0')             { e.preventDefault(); applyZoom(levels.indexOf(100)); }
    });

    // ── 3. STOPLIGHT — red closes tab; all dots dim on window blur ────────────
    document.querySelector('.stoplight__red').addEventListener('click', function () {
      window.close();
    });

    var titlebar = document.querySelector('.app-titlebar');
    var stoplight = document.querySelector('.stoplight');

    function setActive(active) {
      titlebar.classList.toggle('app-titlebar--inactive', !active);
      stoplight.classList.toggle('stoplight--inactive', !active);
    }

    window.addEventListener('blur',  function () { setActive(false); });
    window.addEventListener('focus', function () { setActive(true);  });
    document.addEventListener('visibilitychange', function () {
      setActive(!document.hidden);
    });

  })();
  </script>
</body>
</html>
