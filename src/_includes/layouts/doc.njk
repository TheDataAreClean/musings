---
layout: layouts/base.njk
ogType: article
---

<article class="doc-page">

  <p class="doc-title">{{ title }}</p>

  {% set navRss = true %}{% include "nav.njk" %}

  {% if description %}<p class="doc-description">{{ description }}</p>{% endif %}

  {% if tags and ("snaps" in tags) %}
    {% set sectionLabel = "snaps" %}
    {% set sectionUrl = "/snaps/" %}
  {% elif tags and ("notes" in tags) %}
    {% set sectionLabel = "notes" %}
    {% set sectionUrl = "/notes/" %}
  {% else %}
    {% set sectionLabel = "ideas" %}
    {% set sectionUrl = "/ideas/" %}
  {% endif %}

  {% if not hideMeta %}
  <p class="doc-meta">
    {% if date %}
      <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
      · {{ content | wordcount }} words
      · {{ content | readtime }} min read
    {% endif %}
    · <a class="post-tag" href="{{ sectionUrl }}">{{ sectionLabel }}</a>{% for tag in tags | collectionTags %}<a class="post-tag" href="/tags/{{ tag | lower | replace(' ', '-') }}/">{{ tag }}</a>{% endfor %}
  </p>
  {% endif %}

  <div class="doc-layout">

    <div class="doc-layout__content">
      <div class="doc-body">
        {{ content | safe }}
      </div>

      <nav class="post-nav" aria-label="Post navigation">
        <div class="post-nav__prev">
          <a href="{{ sectionUrl }}">← More {{ sectionLabel }}</a>
        </div>
        <div class="post-nav__next">
          <a href="/">All posts →</a>
        </div>
      </nav>
    </div>


  </div>

</article>
