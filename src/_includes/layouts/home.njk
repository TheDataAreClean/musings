---
layout: layouts/base.njk
---

<div class="doc-page">

  <p class="doc-title">{{ site.shortTitle }}</p>

  {% set navRss = true %}{% include "nav.njk" %}

  {% if description %}<p class="doc-description">{{ description }}</p>{% endif %}

  {% if collections.feed.length %}
  <div class="post-list">
    {% for post in collections.feed %}
    <div class="post-list__item">
      <p class="post-list__title">
        <span class="post-sigil">{{ post.data.tags | postSigil }}</span><a href="{{ post.url }}">{{ post.data.title }}</a>
      </p>
      <p class="post-list__line2">{% for tag in post.data.tags | collectionTags %}<a class="post-tag" href="/tags/{{ tag | lower | replace(' ', '-') }}/">{{ tag }}</a>{% endfor %}<time datetime="{{ post.date | isoDate }}">{{ post.date | isoDate }}</time></p>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p>No posts yet.</p>
  {% endif %}

</div>
