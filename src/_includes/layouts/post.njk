---
layout: layouts/base.njk
ogType: article
---

<article class="doc-page">

  <p class="doc-title">{{ title }}</p>

  <p class="doc-nav">
    <a href="/">Home</a> · <a href="/works/">Works</a> · <a href="/ideas/">Ideas</a> · <a href="/about/">About</a>
  </p>

  <p class="doc-meta">
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    {% if updated %} · Updated <time datetime="{{ updated | isoDate }}">{{ updated | readableDate }}</time>{% endif %}
    · {{ content | wordcount }} words
    · {{ content | readtime }} min read
    {% if tags %}
      {% for tag in tags %}{% if tag != "ideas" %} · <a href="/tags/{{ tag | lower | replace(' ', '-') }}/">{{ tag }}</a>{% endif %}{% endfor %}
    {% endif %}
  </p>

  <div class="doc-layout">

    <div class="doc-layout__content">
      <div class="doc-body">
        {{ content | safe }}
      </div>

      <nav class="post-nav" aria-label="Post navigation">
        {% set allPosts = collections.ideas %}
        {% set postIndex = allPosts | findIndex(page) %}
        <div class="post-nav__prev">
          {% if allPosts[postIndex + 1] %}
          <a href="{{ allPosts[postIndex + 1].url }}">← {{ allPosts[postIndex + 1].data.title }}</a>
          {% endif %}
        </div>
        <div class="post-nav__next">
          {% if allPosts[postIndex - 1] %}
          <a href="{{ allPosts[postIndex - 1].url }}">{{ allPosts[postIndex - 1].data.title }} →</a>
          {% endif %}
        </div>
      </nav>
    </div>

    {% if toc and toc.length > 2 %}
    <aside class="doc-layout__sidebar" aria-label="Table of contents">
      {% include "components/toc.njk" %}
    </aside>
    {% endif %}

  </div>

</article>
