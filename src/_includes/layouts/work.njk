---
layout: layouts/base.njk
ogType: article
---

<article class="doc-page">

  <p class="doc-title">{{ title }}</p>

  <p class="doc-nav">
    <a href="/">Home</a> · <a href="/works/">Works</a> · <a href="/ideas/">Ideas</a> · <a href="/about/">About</a>
  </p>

  <p class="doc-meta">
    {% if year %}{{ year }}{% endif %}
    {% if role %} · {{ role }}{% endif %}
    {% if status %} · {{ status }}{% endif %}
    {% if link %} · <a href="{{ link }}" rel="noopener">↗ View project</a>{% endif %}
    {% if tags %}
      {% for tag in tags %}{% if tag != "works" %} · <a href="/tags/{{ tag | lower | replace(' ', '-') }}/">{{ tag }}</a>{% endif %}{% endfor %}
    {% endif %}
  </p>

  <div class="doc-layout">
    <div class="doc-layout__content">
      <div class="doc-body">
        {{ content | safe }}
      </div>
    </div>

    {% if toc and toc.length > 2 %}
    <aside class="doc-layout__sidebar" aria-label="Table of contents">
      {% include "components/toc.njk" %}
    </aside>
    {% endif %}
  </div>

</article>
