---
layout: layouts/base.njk
title: Snaps
---

<div class="doc-page">

  <p class="doc-title">Snaps</p>

  {% set navRss = true %}{% include "nav.njk" %}

  <p class="doc-description">Moments that stuck.</p>

  {% if collections.snaps.length %}
  <div class="post-list">
    {% for post in collections.snaps %}
    <div class="post-list__item">
      <p class="post-list__title"><a href="{{ post.url }}">{{ post.data.title }}</a></p>
      <p class="post-list__line2">{% for tag in post.data.tags | collectionTags %}<a class="post-tag" href="/tags/{{ tag }}/">{{ tag }}</a>{% endfor %}<time datetime="{{ post.date | isoDate }}">{{ post.date | isoDate }}</time></p>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p>No snaps yet.</p>
  {% endif %}

</div>
