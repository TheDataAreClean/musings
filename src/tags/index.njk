---
layout: layouts/base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - ideas
    - notes
    - shots
    - feed
permalink: /tags/{{ tag }}/
eleventyExcludeFromCollections: true
---

<div class="doc-page">

  <p class="doc-title">{{ tag }}</p>

  <p class="doc-nav">
    <a href="/">Home</a> · <a href="/ideas/">Ideas</a> · <a href="/notes/">Notes</a> · <a href="/about/">About</a>
  </p>

  <p class="doc-meta">{{ collections[tag] | length }} {% if collections[tag] | length == 1 %}post{% else %}posts{% endif %} tagged "{{ tag }}"</p>

  {% set taggedPosts = collections[tag] | sort(true, false, "date") %}
  {% if taggedPosts.length %}
  <div class="post-list">
    {% for post in taggedPosts %}
    <div class="post-list__item">
      <p class="post-list__title">
        <span class="post-sigil">{% if post.data.tags and "ideas" in post.data.tags %}→{% else %}·{% endif %}</span><a href="{{ post.url }}">{{ post.data.title }}</a>
      </p>
      <p class="post-list__line2"><time datetime="{{ post.date | isoDate }}">{{ post.date | isoDate }}</time></p>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p>No posts tagged "{{ tag }}".</p>
  {% endif %}

</div>
